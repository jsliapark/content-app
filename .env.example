# Required
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Optional — comma-separated or JSON array (e.g. ["brandvoice-mcp==0.1.1"])
# BRANDVOICE_COMMAND=uvx
# BRANDVOICE_ARGS=brandvoice-mcp

# Optional — Claude model id, graph retries / alignment, SQLite URL, log level
# DEFAULT_MODEL=claude-sonnet-4-20250514
# MAX_RETRIES=3
# ALIGNMENT_THRESHOLD=70
# DATABASE_URL=sqlite:///content_app.db
# LOG_LEVEL=INFO

# Optional — draft agent web search
# TAVILY_API_KEY=
